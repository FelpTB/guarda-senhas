{
  "name": "passvault-web",
  "version": "2.1.0",
  "description": "PassVault Pro - Gestor de senhas multiutilizador",
  "main": "main.js",
  "scripts": {
    "build:web": "esbuild public/app.jsx --bundle --outfile=public/app.bundle.js --loader:.jsx=jsx --minify",
    "build:desktop": "esbuild desktop/legacy.jsx --bundle --outfile=legacy.bundle.js --loader:.jsx=jsx --minify",
    "build": "npm run build:web && npm run build:desktop",
    "start": "node server/index.js",
    "dev": "npm run build:web && node --watch server/index.js",
    "electron": "npm run build:desktop && electron .",
    "dist": "npm run build:desktop && electron-builder"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "esbuild": "^0.24.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.263.1",
    "classic-level": "^2.0.0",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "classic-level": "^3.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.passvault.app",
    "productName": "PassVault Pro",
    "files": [
      "main.js",
      "index.html",
      "legacy.bundle.js",
      "desktop/preload.js",
      "desktop/recovery.js"
    ],
    "win": {
      "target": "portable"
    }
  }
}
